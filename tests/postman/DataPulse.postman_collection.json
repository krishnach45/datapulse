{
  "info": {
    "_postman_id": "datapulse-api-collection",
    "name": "DataPulse API",
    "description": "Complete test collection for the DataPulse real-time e-commerce analytics API.\nRun with Newman:\n  newman run DataPulse.postman_collection.json -e dev.postman_environment.json",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body is healthy', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('healthy');",
                  "  pm.expect(json.service).to.eql('datapulse-api');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/", "host": ["{{base_url}}"], "path": [""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has docs link', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('docs');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Metrics",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/metrics", "host": ["{{base_url}}"], "path": ["metrics"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Contains Prometheus metrics', () => {",
                  "  pm.expect(pm.response.text()).to.include('datapulse_http_requests_total');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "KPIs",
      "item": [
        {
          "name": "Summary Dashboard",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/kpis/summary", "host": ["{{base_url}}"], "path": ["api", "v1", "kpis", "summary"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has summary fields', () => {",
                  "  const data = pm.response.json().data;",
                  "  pm.expect(data).to.have.property('total_revenue');",
                  "  pm.expect(data).to.have.property('total_orders');",
                  "  pm.expect(data).to.have.property('avg_order_value');",
                  "  pm.expect(data.total_revenue).to.be.above(0);",
                  "});",
                  "pm.test('Response time < 500ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Revenue - All Regions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/kpis/revenue?limit=24",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "kpis", "revenue"],
              "query": [{ "key": "limit", "value": "24" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => {",
                  "  pm.expect(pm.response.json().data).to.be.an('array');",
                  "});",
                  "pm.test('Respects limit', () => {",
                  "  pm.expect(pm.response.json().data.length).to.be.at.most(24);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Revenue - Europe Only",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/kpis/revenue?region=Europe",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "kpis", "revenue"],
              "query": [{ "key": "region", "value": "Europe" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('All results are Europe', () => {",
                  "  const data = pm.response.json().data;",
                  "  data.forEach(row => pm.expect(row.region).to.eql('Europe'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Top Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/kpis/products", "host": ["{{base_url}}"], "path": ["api", "v1", "kpis", "products"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Max 10 products', () => {",
                  "  pm.expect(pm.response.json().data.length).to.be.at.most(10);",
                  "});",
                  "pm.test('Products have revenue field', () => {",
                  "  const data = pm.response.json().data;",
                  "  if (data.length > 0) pm.expect(data[0]).to.have.property('revenue');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Top Products - Electronics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/kpis/products?category=Electronics",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "kpis", "products"],
              "query": [{ "key": "category", "value": "Electronics" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Conversion Funnel",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/kpis/conversion", "host": ["{{base_url}}"], "path": ["api", "v1", "kpis", "conversion"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has funnel fields', () => {",
                  "  const data = pm.response.json().data;",
                  "  ['total_clicks','added_to_cart','completed_orders',",
                  "   'conversion_rate_pct','cart_abandonment_pct'].forEach(f => {",
                  "    pm.expect(data).to.have.property(f);",
                  "  });",
                  "});",
                  "pm.test('Rates in valid range', () => {",
                  "  const data = pm.response.json().data;",
                  "  pm.expect(data.conversion_rate_pct).to.be.within(0, 100);",
                  "  pm.expect(data.cart_abandonment_pct).to.be.within(0, 100);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Inventory Alerts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/kpis/inventory?alerts_only=true",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "kpis", "inventory"],
              "query": [{ "key": "alerts_only", "value": "true" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('All items are low stock', () => {",
                  "  pm.response.json().data.forEach(item => {",
                  "    pm.expect(item.low_stock_alert).to.be.true;",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Regions List",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/kpis/regions", "host": ["{{base_url}}"], "path": ["api", "v1", "kpis", "regions"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Regions is array', () => {",
                  "  pm.expect(pm.response.json().regions).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
